#!/usr/bin/env php
<?php

$autoloaders = [
    __DIR__ . '/vendor/autoload.php',
    __DIR__ . '/../../autoload.php',
];

$loaded = false;
foreach ($autoloaders as $file) {
    if (file_exists($file)) {
        require $file;
        $loaded = true;
        break;
    }
}

if (!$loaded) {
    fwrite(STDERR, "Error: Autoloader not found. Please run 'composer install'.\n");
    exit(1);
}

use Vatts\Console\ConsoleApplication;
use Vatts\Console\Commands\MakeController;
use Vatts\Console\Commands\MakeModel;
use Vatts\Console\Commands\MakeMiddleware;
// use Vatts\Console\Command; // Descomente ou ajuste caso precise referenciar a classe base

$app = new ConsoleApplication();

// Registro de comandos core
$app->registerCommand(new MakeController());
$app->registerCommand(new MakeModel());
$app->registerCommand(new MakeMiddleware());

// Autoload de comandos do projeto
$commandsDir = getcwd() . DIRECTORY_SEPARATOR . 'app' . DIRECTORY_SEPARATOR . 'commands';

if (is_dir($commandsDir)) {
    $iterator = new \RecursiveIteratorIterator(new \RecursiveDirectoryIterator($commandsDir));

    foreach ($iterator as $file) {
        if ($file->isFile() && $file->getExtension() === 'php') {

            // 1. Fotografa as classes existentes antes do require
            $classesBefore = get_declared_classes();

            require_once $file->getPathname();

            // 2. Compara com as classes após o require para descobrir a classe nova
            $classesAfter = get_declared_classes();
            $newClasses = array_diff($classesAfter, $classesBefore);

            foreach ($newClasses as $className) {
                try {
                    $reflection = new \ReflectionClass($className);

                    // 3. Garante que é uma classe instanciável (ignora abstract/interfaces)
                    // e que realmente é um comando válido antes de registrar
                    if (!$reflection->isAbstract()) {
                        // Opcional: Você pode adicionar && $reflection->isSubclassOf(Command::class) no IF acima
                        // para garantir que a classe herda da sua base de comandos.

                        $app->registerCommand($reflection->newInstance());
                    }
                } catch (\ReflectionException $e) {
                    continue; // Ignora se houver problema ao refletir a classe
                }
            }
        }
    }
}

$app->run($argv);