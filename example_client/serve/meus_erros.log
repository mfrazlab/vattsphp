 -f server.properties ]; then\n    echo -e \"${C_LBLUE}[Configura\u00e7\u00e3o]${C_NC} Gerando propriedades do servidor base...\"\n    echo \"server-ip=0.0.0.0\" > server.properties\n    echo \"server-port=${SERVER_PORT}\" >> server.properties\n    echo \"online-mode=${ONLINE_MODE}\" >> server.properties\n    echo \"white-list=${WHITELIST}\" >> server.properties\n    echo \"view-distance=${VIEW_DISTANCE}\" >> server.properties\n    echo \"allow-nether=${ALLOW_NETHER}\" >> server.properties\n    echo \"difficulty=${DIFFICULTY}\" >> server.properties\n    echo \"max-players=${MAX_PLAYERS}\" >> server.properties\nfi\n\nif [ ! -f bukkit.yml ]; then\n    echo \"settings:\" > bukkit.yml\n    echo \"  allow-end: ${ALLOW_END}\" >> bukkit.yml\nfi\n\necho -e \"${C_GREEN}[Sucesso]${C_NC} Instala\u00e7\u00e3o conclu\u00edda com sucesso!\"\necho -e \"${C_LBLUE}[Orchestrator]${C_NC} O servidor j\u00e1 pode ser iniciado no painel.\"","installImage":"alpine","installEntrypoint":"ash","rootAcess":null,"maintainable":null},"token":"7dcd5010-b674-417d-b121-113eb9200a9a"}
