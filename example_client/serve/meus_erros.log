pi.papermc.io\/v2\/projects\/paper\/versions\/${MINECRAFT_VERSION} | jq -r '.builds[-1]')\n    JAR_NAME=\"paper-${MINECRAFT_VERSION}-${BUILD}.jar\"\n    DOWNLOAD_URL=\"https:\/\/api.papermc.io\/v2\/projects\/paper\/versions\/${MINECRAFT_VERSION}\/builds\/${BUILD}\/downloads\/${JAR_NAME}\"\n\nelif [ \"$SOFTWARE_TYPE\" == \"purpur\" ]; then\n    if [ \"$MINECRAFT_VERSION\" == \"latest\" ]; then\n        MINECRAFT_VERSION=$(curl -s https:\/\/api.purpurmc.org\/v2\/purpur | jq -r '.versions[-1]')\n    fi\n    DOWNLOAD_URL=\"https:\/\/api.purpurmc.org\/v2\/purpur\/${MINECRAFT_VERSION}\/latest\/download\"\n\nelif [ \"$SOFTWARE_TYPE\" == \"vanilla\" ]; then\n    MANIFEST=$(curl -s https:\/\/piston-meta.mojang.com\/mc\/game\/version_manifest_v2.json)\n    if [ \"$MINECRAFT_VERSION\" == \"latest\" ]; then\n        MINECRAFT_VERSION=$(echo $MANIFEST | jq -r '.latest.release')\n    fi\n    VERSION_URL=$(echo $MANIFEST | jq -r --arg VERSION \"$MINECRAFT_VERSION\" '.versions[] | select(.id == $VERSION) | .url')\n    DOWNLOAD_URL=$(curl -s $VERSION_URL | jq -r '.downloads.server.url')\n\nelif [ \"$SOFTWARE_TYPE\" == \"fabric\" ]; then\n    if [ \"$MINECRAFT_VERSION\" == \"latest\" ]; then\n        MANIFEST=$(curl -s https:\/\/piston-meta.mojang.com\/mc\/game\/version_manifest_v2.json)\n        MINECRAFT_VERSION=$(echo $MANIFEST | jq -r '.latest.release')\n    fi\n    LOADER_VERSION=$(curl -s https:\/\/meta.fabricmc.net\/v2\/versions\/loader | jq -r '.[0].version')\n    INSTALLER_VERSION=$(curl -s https:\/\/meta.fabricmc.net\/v2\/versions\/installer | jq -r '.[0].version')\n    DOWNLOAD_URL=\"https:\/\/meta.fabricmc.net\/v2\/versions\/loader\/${MINECRAFT_VERSION}\/${LOADER_VERSION}\/${INSTALLER_VERSION}\/server\/jar\"\nelse\n    echo -e \"${C_PINK}[Erro]${C_NC} O software selecionado n\u00e3o \u00e9 suportado por este Egg.\"\n    exit 1\nfi\n\necho -e \"${C_LBLUE}[Download]${C_NC} Baixando os arquivos base de ${DOWNLOAD_URL}...\"\ncurl -o ${SERVER_JARFILE} ${DOWNLOAD_URL}\n\nif [ ! -f server.properties ]; then\n    echo -e \"${C_LBLUE}[Configura\u00e7\u00e3o]${C_NC} Gerando propriedades do servidor base...\"\n    echo \"server-ip=0.0.0.0\" > server.properties\n    echo \"server-port=${SERVER_PORT}\" >> server.properties\n    echo \"online-mode=${ONLINE_MODE}\" >> server.properties\n    echo \"white-list=${WHITELIST}\" >> server.properties\n    echo \"view-distance=${VIEW_DISTANCE}\" >> server.properties\n    echo \"allow-nether=${ALLOW_NETHER}\" >> server.properties\n    echo \"difficulty=${DIFFICULTY}\" >> server.properties\n    echo \"max-players=${MAX_PLAYERS}\" >> server.properties\nfi\n\nif [ ! -f bukkit.yml ]; then\n    echo \"settings:\" > bukkit.yml\n    echo \"  allow-end: ${ALLOW_END}\" >> bukkit.yml\nfi\n\necho -e \"${C_GREEN}[Sucesso]${C_NC} Instala\u00e7\u00e3o conclu\u00edda com sucesso!\"\necho -e \"${C_LBLUE}[Orchestrator]${C_NC} O servidor j\u00e1 pode ser iniciado no painel.\"","installImage":"alpine","installEntrypoint":"ash","rootAcess":null,"maintainable":null},"token":"7dcd5010-b674-417d-b121-113eb9200a9a"}
